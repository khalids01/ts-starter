{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc --noEmit",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "bun run --hot src/index.ts",
    "start": "bun run dist/index.js",
    "test": "bun test ./tests"
  },
  "dependencies": {
    "@auth": "workspace:*",
    "@config": "workspace:*",
    "@db": "workspace:*",
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/openapi": "^1.4.14",
    "@env": "workspace:*",
    "@polar-sh/adapter-utils": "0.4.3",
    "@polar-sh/elysia": "^0.5.3",
    "@polar-sh/sdk": "0.42.5",
    "@redis": "workspace:*",
    "better-auth": "^1.4.18",
    "dotenv": "^17.3.1",
    "elysia": "^1.4.25",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "^1.3.9",
    "@types/nodemailer": "^8.0.0",
    "tsdown": "^0.20.3",
    "typescript": "^6.0.2"
  }
}
