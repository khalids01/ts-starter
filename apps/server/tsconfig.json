{
  "extends": "../../packages/config/tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "outDir": "dist",
    "rootDir": "../..",
    "paths": {
      "@/*": ["./src/*"],
      "@auth": ["../../packages/auth/src"],
      "@db": ["../../packages/db/src"],
      "@env/*": ["../../packages/env/src/*"],
      "@config": ["../../packages/config/src/config.ts"],
      "@email": ["../../packages/email/src"],
      "@redis": ["../../packages/redis/src"]
    },
    "jsx": "react-jsx"
  },
  "include": [
    "src/**/*",
    "../../packages/auth/src/**/*",
    "../../packages/db/src/**/*",
    "../../packages/db/prisma/generated/**/*",
    "../../packages/email/src/**/*",
    "../../packages/env/src/**/*",
    "../../packages/config/src/**/*",
    "../../packages/redis/src/**/*"
  ]
}
