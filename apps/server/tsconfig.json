{
  "extends": "../../packages/config/tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "outDir": "dist",
    "rootDir": "../..",
    "paths": {
      "@/*": ["./src/*"],
      "@auth/server": ["../../packages/auth/src/index.server.ts"],
      "@auth/client": ["../../packages/auth/src/index.client.ts"],
      "@db/server": ["../../packages/db/src/index.server.ts"],
      "@db/server/rbac/assignments": ["../../packages/db/src/rbac/assignments.server.ts"],
      "@db/server/rbac/session": ["../../packages/db/src/rbac/session.server.ts"],
      "@db/server/rbac/prisma": ["../../packages/db/src/rbac/prisma.server.ts"],
      "@db/server/rbac/roles": ["../../packages/db/src/rbac/roles.server.ts"],
      "@db/server/rbac/sync-role-permissions": ["../../packages/db/src/rbac/sync-role-permissions.server.ts"],
      "@db/server/rbac/keys": ["../../packages/db/src/rbac/keys.ts"],
      "@db/server/rbac/cache/effective": ["../../packages/db/src/rbac/cache/effective.server.ts"],
      "@db/server/rbac/cache/invalidate": ["../../packages/db/src/rbac/cache/invalidate.server.ts"],
      "@db/server/rbac/cache/role-permissions": ["../../packages/db/src/rbac/cache/role-permissions.server.ts"],
      "@db/server/rbac/resolve/build-effective": ["../../packages/db/src/rbac/resolve/build-effective.server.ts"],
      "@db/server/rbac/resolve/get-session-rbac": ["../../packages/db/src/rbac/resolve/get-session-rbac.server.ts"],
      "@db/server/rbac/resolve/load-role-permissions": ["../../packages/db/src/rbac/resolve/load-role-permissions.server.ts"],
      "@db/server/rbac/resolve/load-snapshot": ["../../packages/db/src/rbac/resolve/load-snapshot.server.ts"],
      "@db/server/rbac/resolve/load-user-context": ["../../packages/db/src/rbac/resolve/load-user-context.server.ts"],
      "@db/server/rbac/resolve/load-user-roles": ["../../packages/db/src/rbac/resolve/load-user-roles.server.ts"],
      "@env/client": ["../../packages/env/src/env.client.ts"],
      "@env/server": ["../../packages/env/src/env.server.ts"],
      "@config": ["../../packages/config/src/config.ts"],
      "@email/server": ["../../packages/email/src/index.server.ts"],
      "@redis/server": ["../../packages/redis/src/index.server.ts"],
      "@rbac": ["../../packages/rbac/src"]
    },
    "jsx": "react-jsx"
  },
  "include": [
    "src/**/*",
    "../../packages/auth/src/**/*",
    "../../packages/db/src/**/*",
    "../../packages/db/prisma/generated/**/*",
    "../../packages/db/prisma/seed/**/*",
    "../../packages/email/src/**/*",
    "../../packages/env/src/**/*",
    "../../packages/config/src/**/*",
    "../../packages/redis/src/**/*",
    "../../packages/rbac/src/**/*"
  ]
}
