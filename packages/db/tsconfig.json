{
  "extends": "../config/tsconfig.base.json",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "..",
    "composite": true,
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "paths": {
      "@env/server": ["../env/src/env.server.ts"],
      "@env/client": ["../env/src/env.client.ts"],
      "@config": ["../config/src/config.ts"],
      "@config/brand": ["../config/src/brand.config.ts"],
      "@rbac": ["../rbac/src/index.ts"],
      "@rbac/*": ["../rbac/src/*"],
      "@redis/server": ["../redis/src/index.server.ts"]
    }
  },
  "include": [
    "src/**/*",
    "prisma/generated/**/*",
    "prisma/seed/**/*",
    "../env/src/**/*",
    "../config/src/**/*",
    "../rbac/src/**/*",
    "../redis/src/**/*"
  ]
}
