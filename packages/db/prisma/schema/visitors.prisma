model VisitorIdentity {
  id          String   @id @default(cuid())
  visitorId   String   @unique
  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())
  firstUserId String?
  lastUserId  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sessions VisitorSession[]

  @@index([firstSeenAt])
  @@index([lastSeenAt])
  @@map("visitor_identity")
}

model VisitorSession {
  id                String          @id @default(cuid())
  visitorIdentityId String
  visitorIdentity   VisitorIdentity @relation(fields: [visitorIdentityId], references: [id], onDelete: Cascade)
  userId            String?
  isBot             Boolean         @default(false)
  startedAt         DateTime        @default(now())
  lastSeenAt        DateTime        @default(now())
  endedAt           DateTime        @default(now())
  entryPath         String
  lastPath          String
  referrer          String?
  deviceType        String?
  country           String?
  ipHash            String?
  eventCount        Int             @default(1)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([visitorIdentityId, startedAt])
  @@index([visitorIdentityId, isBot, lastSeenAt])
  @@index([lastSeenAt])
  @@index([startedAt])
  @@index([startedAt, userId])
  @@index([isBot, startedAt])
  @@index([userId, startedAt])
  @@map("visitor_session")
}
