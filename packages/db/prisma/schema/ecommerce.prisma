enum ProductStatus {
  draft
  active
  archived
}

enum CategoryBrandPolicy {
  hidden
  optional
  required
  default_store
}

enum ProductAttributeType {
  text
  number
  boolean
  color
}

enum CategoryAttributeScope {
  product
  variant
  batch
}

enum AttributeInputType {
  text
  textarea
  number
  boolean
  select
  multiselect
  color
  date
}

enum WeightUnit {
  g
  kg
  lb
  oz
}

enum InventoryMovementType {
  purchase
  sale_reserve
  sale_commit
  reservation_release
  return
  adjustment
  transfer_in
  transfer_out
}

enum StockReservationStatus {
  active
  committed
  released
  expired
}

model Category {
  id             String              @id @default(cuid())
  name           String
  slug           String              @unique
  description    String?             @db.Text
  parentId       String?
  parent         Category?           @relation("CategoryChildren", fields: [parentId], references: [id], onDelete: SetNull)
  children       Category[]          @relation("CategoryChildren")
  imageUrl       String?
  iconUrl        String?
  brandPolicy    CategoryBrandPolicy @default(optional)
  showStoreBrand Boolean             @default(false)
  isActive       Boolean             @default(true)
  isFeatured     Boolean             @default(false)
  sortOrder      Int                 @default(0)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  products   Product[]
  attributes CategoryAttribute[]

  @@index([parentId])
  @@index([isActive])
  @@index([isFeatured])
  @@index([sortOrder])
  @@map("category")
}

model ProductBrand {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?  @db.Text
  logoUrl     String?
  websiteUrl  String?
  isActive    Boolean  @default(true)
  isFeatured  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products Product[]

  @@index([isActive])
  @@index([isFeatured])
  @@map("product_brand")
}

model Product {
  id              String        @id @default(cuid())
  name            String
  slug            String        @unique
  description     String?       @db.Text
  descriptionHtml String?       @db.Text
  categoryId      String
  category        Category      @relation(fields: [categoryId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  brandId         String?
  brand           ProductBrand? @relation(fields: [brandId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  status          ProductStatus @default(draft)
  isActive        Boolean       @default(true)
  isFeatured      Boolean       @default(false)
  media           Json?
  seoTitle        String?
  seoDescription  String?       @db.Text
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  variants             ProductVariant[]
  attributeAssignments ProductAttributeAssignment[]

  @@index([categoryId])
  @@index([brandId])
  @@index([status])
  @@index([isActive])
  @@index([isFeatured])
  @@map("product")
}

model ProductVariant {
  id                 String      @id @default(cuid())
  productId          String
  product            Product     @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  sku                String      @unique
  barcode            String?     @unique
  name               String
  attributesSnapshot Json?
  price              Decimal     @db.Decimal(12, 2)
  compareAtPrice     Decimal?    @db.Decimal(12, 2)
  costPrice          Decimal?    @db.Decimal(12, 2)
  currency           String      @default("BDT")
  isDefault          Boolean     @default(false)
  isActive           Boolean     @default(true)
  media              Json?
  weightValue        Decimal?    @db.Decimal(10, 3)
  weightUnit         WeightUnit?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  attributeValues  ProductVariantAttributeValue[]
  inventoryBatches InventoryBatch[]
  inventoryStocks  InventoryStock[]
  movements        InventoryMovement[]
  reservations     StockReservation[]

  @@index([productId])
  @@index([isActive])
  @@index([isDefault])
  @@map("product_variant")
}

model ProductAttribute {
  id              String               @id @default(cuid())
  name            String
  slug            String               @unique
  type            ProductAttributeType @default(text)
  filterable      Boolean              @default(false)
  variantDefining Boolean              @default(false)
  sortOrder       Int                  @default(0)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  values             ProductAttributeValue[]
  categoryAttributes CategoryAttribute[]
  productAssignments ProductAttributeAssignment[]
  batchAssignments   InventoryBatchAttributeAssignment[]

  @@index([filterable])
  @@index([variantDefining])
  @@index([sortOrder])
  @@map("product_attribute")
}

model ProductAttributeValue {
  id          String           @id @default(cuid())
  attributeId String
  attribute   ProductAttribute @relation(fields: [attributeId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  value       String
  label       String
  sortOrder   Int              @default(0)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  variants           ProductVariantAttributeValue[]
  productAssignments ProductAttributeAssignment[]
  batchAssignments   InventoryBatchAttributeAssignment[]

  @@unique([attributeId, value])
  @@index([attributeId])
  @@index([sortOrder])
  @@map("product_attribute_value")
}

model ProductVariantAttributeValue {
  variantId        String
  attributeValueId String
  variant          ProductVariant        @relation(fields: [variantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  attributeValue   ProductAttributeValue @relation(fields: [attributeValueId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@id([variantId, attributeValueId])
  @@index([attributeValueId])
  @@map("product_variant_attribute_value")
}

model CategoryAttribute {
  id              String                 @id @default(cuid())
  categoryId      String
  category        Category               @relation(fields: [categoryId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  attributeId     String
  attribute       ProductAttribute       @relation(fields: [attributeId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  scope           CategoryAttributeScope
  required        Boolean                @default(false)
  filterable      Boolean                @default(false)
  variantDefining Boolean                @default(false)
  comparable      Boolean                @default(false)
  inputType       AttributeInputType     @default(text)
  unit            String?
  groupName       String?
  helpText        String?                @db.Text
  placeholder     String?
  sortOrder       Int                    @default(0)
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  @@unique([categoryId, attributeId, scope])
  @@index([categoryId])
  @@index([attributeId])
  @@index([scope])
  @@index([filterable])
  @@index([variantDefining])
  @@index([sortOrder])
  @@map("category_attribute")
}

model ProductAttributeAssignment {
  id               String                 @id @default(cuid())
  productId        String
  product          Product                @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  attributeId      String
  attribute        ProductAttribute       @relation(fields: [attributeId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  attributeValueId String?
  attributeValue   ProductAttributeValue? @relation(fields: [attributeValueId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  rawText          String?                @db.Text
  rawNumber        Decimal?               @db.Decimal(16, 4)
  rawBoolean       Boolean?
  rawDate          DateTime?
  displayValue     String?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  @@unique([productId, attributeId])
  @@index([productId])
  @@index([attributeId])
  @@index([attributeValueId])
  @@map("product_attribute_assignment")
}

model Supplier {
  id          String   @id @default(cuid())
  name        String
  contactName String?
  email       String?
  phone       String?
  address     String?  @db.Text
  notes       String?  @db.Text
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  batches InventoryBatch[]

  @@index([isActive])
  @@index([email])
  @@map("supplier")
}

model InventoryLocation {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  address   String?  @db.Text
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stocks       InventoryStock[]
  movements    InventoryMovement[]
  reservations StockReservation[]

  @@index([isActive])
  @@map("inventory_location")
}

model InventoryBatch {
  id          String         @id @default(cuid())
  variantId   String
  variant     ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  supplierId  String?
  supplier    Supplier?      @relation(fields: [supplierId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  batchNumber String?
  expiryDate  DateTime?
  receivedAt  DateTime       @default(now())
  unitCost    Decimal?       @db.Decimal(12, 4)
  notes       String?        @db.Text

  stocks               InventoryStock[]
  movements            InventoryMovement[]
  reservations         StockReservation[]
  attributeAssignments InventoryBatchAttributeAssignment[]

  @@index([variantId])
  @@index([supplierId])
  @@index([expiryDate])
  @@map("inventory_batch")
}

model InventoryBatchAttributeAssignment {
  id               String                 @id @default(cuid())
  batchId          String
  batch            InventoryBatch         @relation(fields: [batchId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  attributeId      String
  attribute        ProductAttribute       @relation(fields: [attributeId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  attributeValueId String?
  attributeValue   ProductAttributeValue? @relation(fields: [attributeValueId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  rawText          String?                @db.Text
  rawNumber        Decimal?               @db.Decimal(16, 4)
  rawBoolean       Boolean?
  rawDate          DateTime?
  displayValue     String?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  @@unique([batchId, attributeId])
  @@index([batchId])
  @@index([attributeId])
  @@index([attributeValueId])
  @@map("inventory_batch_attribute_assignment")
}

model InventoryStock {
  id               String            @id @default(cuid())
  variantId        String
  variant          ProductVariant    @relation(fields: [variantId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  locationId       String
  location         InventoryLocation @relation(fields: [locationId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  batchId          String?
  batch            InventoryBatch?   @relation(fields: [batchId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  quantityOnHand   Int               @default(0)
  quantityReserved Int               @default(0)
  reorderLevel     Int?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@unique([variantId, locationId, batchId])
  @@index([variantId])
  @@index([locationId])
  @@index([batchId])
  @@map("inventory_stock")
}

model InventoryMovement {
  id            String                @id @default(cuid())
  variantId     String
  variant       ProductVariant        @relation(fields: [variantId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  locationId    String
  location      InventoryLocation     @relation(fields: [locationId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  batchId       String?
  batch         InventoryBatch?       @relation(fields: [batchId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  type          InventoryMovementType
  delta         Int
  unitCost      Decimal?              @db.Decimal(12, 4)
  reason        String?               @db.Text
  referenceType String?
  referenceId   String?
  actorUserId   String?
  actorUser     User?                 @relation("InventoryMovementActor", fields: [actorUserId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  createdAt     DateTime              @default(now())

  @@index([variantId, createdAt])
  @@index([locationId, createdAt])
  @@index([batchId])
  @@index([type, createdAt])
  @@index([referenceType, referenceId])
  @@index([actorUserId])
  @@map("inventory_movement")
}

model StockReservation {
  id            String                 @id @default(cuid())
  variantId     String
  variant       ProductVariant         @relation(fields: [variantId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  locationId    String
  location      InventoryLocation      @relation(fields: [locationId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  batchId       String?
  batch         InventoryBatch?        @relation(fields: [batchId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  quantity      Int
  status        StockReservationStatus @default(active)
  expiresAt     DateTime
  referenceType String?
  referenceId   String?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  @@index([variantId])
  @@index([locationId])
  @@index([batchId])
  @@index([status, expiresAt])
  @@index([referenceType, referenceId])
  @@map("stock_reservation")
}
