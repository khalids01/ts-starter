enum ProductStatus {
  draft
  active
  archived
}

enum CategoryBrandPolicy {
  hidden
  optional
  required
  default_store
}

enum ProductAttributeType {
  text
  number
  boolean
  color
}

enum CategoryAttributeScope {
  product
  variant
  batch
}

enum AttributeInputType {
  text
  textarea
  number
  boolean
  select
  multiselect
  color
  date
}

enum WeightUnit {
  g
  kg
  lb
  oz
}

enum InventoryMovementType {
  purchase
  sale_reserve
  sale_commit
  reservation_release
  return
  adjustment
  transfer_in
  transfer_out
}

enum StockReservationStatus {
  active
  committed
  released
  expired
}

enum OrderStatus {
  pending
  confirmed
  processing
  completed
  cancelled
}

enum PaymentStatus {
  unpaid
  authorized
  paid
  partially_refunded
  refunded
  failed
}

enum DeliveryStatus {
  unfulfilled
  preparing
  ready_to_ship
  shipped
  out_for_delivery
  delivered
  returned
  failed
}

enum OrderInventoryStatus {
  reserved
  committed
  released
  restocked
}

enum PaymentMethod {
  cash_on_delivery
  manual_bank
  manual_mobile
  online_gateway
}

enum OrderStatusEventType {
  order
  payment
  delivery
}

enum OrderAddressType {
  shipping
  billing
}

model Category {
  id             String              @id @default(cuid())
  name           String
  slug           String              @unique
  description    String?             @db.Text
  parentId       String?
  parent         Category?           @relation("CategoryChildren", fields: [parentId], references: [id], onDelete: SetNull)
  children       Category[]          @relation("CategoryChildren")
  imageUrl       String?
  iconUrl        String?
  brandPolicy    CategoryBrandPolicy @default(optional)
  showStoreBrand Boolean             @default(false)
  isActive       Boolean             @default(true)
  isFeatured     Boolean             @default(false)
  sortOrder      Int                 @default(0)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  products   Product[]
  attributes CategoryAttribute[]

  @@index([parentId])
  @@index([isActive])
  @@index([isFeatured])
  @@index([sortOrder])
  @@map("category")
}

model ProductBrand {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?  @db.Text
  logoUrl     String?
  websiteUrl  String?
  isActive    Boolean  @default(true)
  isFeatured  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products Product[]

  @@index([isActive])
  @@index([isFeatured])
  @@map("product_brand")
}

model Product {
  id              String        @id @default(cuid())
  name            String
  slug            String        @unique
  description     String?       @db.Text
  descriptionHtml String?       @db.Text
  categoryId      String
  category        Category      @relation(fields: [categoryId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  brandId         String?
  brand           ProductBrand? @relation(fields: [brandId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  status          ProductStatus @default(draft)
  isActive        Boolean       @default(true)
  isFeatured      Boolean       @default(false)
  isTrending      Boolean       @default(false)
  badgeLabel      String?
  coverImageUrl   String?
  searchKeywords  String[]      @default([])
  seoTitle        String?
  seoDescription  String?       @db.Text
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  variants             ProductVariant[]
  attributeAssignments ProductAttributeAssignment[]
  highlights           ProductHighlight[]
  orderLineItems       OrderLineItem[]

  @@index([categoryId])
  @@index([brandId])
  @@index([status])
  @@index([isActive])
  @@index([isFeatured])
  @@index([isTrending])
  @@map("product")
}

model ProductVariant {
  id                 String      @id @default(cuid())
  productId          String
  product            Product     @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  sku                String      @unique
  barcode            String?     @unique
  name               String
  attributesSnapshot Json?
  price              Decimal     @db.Decimal(12, 2)
  compareAtPrice     Decimal?    @db.Decimal(12, 2)
  costPrice          Decimal?    @db.Decimal(12, 2)
  currency           String      @default("BDT")
  isDefault          Boolean     @default(false)
  isActive           Boolean     @default(true)
  imageUrls          String[]    @default([])
  weightValue        Decimal?    @db.Decimal(10, 3)
  weightUnit         WeightUnit?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  attributeValues  ProductVariantAttributeValue[]
  inventoryBatches InventoryBatch[]
  inventoryStocks  InventoryStock[]
  movements        InventoryMovement[]
  reservations     StockReservation[]
  orderLineItems   OrderLineItem[]
  cartItems        CartItem[]

  @@index([productId])
  @@index([isActive])
  @@index([isDefault])
  @@map("product_variant")
}

model ProductHighlight {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  title       String
  description String?  @db.Text
  iconUrl     String?
  imageUrl    String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([productId])
  @@index([sortOrder])
  @@map("product_highlight")
}

model ProductAttribute {
  id              String               @id @default(cuid())
  name            String
  slug            String               @unique
  type            ProductAttributeType @default(text)
  filterable      Boolean              @default(false)
  variantDefining Boolean              @default(false)
  sortOrder       Int                  @default(0)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  values             ProductAttributeValue[]
  categoryAttributes CategoryAttribute[]
  productAssignments ProductAttributeAssignment[]
  batchAssignments   InventoryBatchAttributeAssignment[]

  @@index([filterable])
  @@index([variantDefining])
  @@index([sortOrder])
  @@map("product_attribute")
}

model ProductAttributeValue {
  id          String           @id @default(cuid())
  attributeId String
  attribute   ProductAttribute @relation(fields: [attributeId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  value       String
  label       String
  sortOrder   Int              @default(0)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  variants                ProductVariantAttributeValue[]
  productAssignments      ProductAttributeAssignment[]
  productAssignmentValues ProductAttributeAssignmentValue[]
  batchAssignments        InventoryBatchAttributeAssignment[]

  @@unique([attributeId, value])
  @@index([attributeId])
  @@index([sortOrder])
  @@map("product_attribute_value")
}

model ProductVariantAttributeValue {
  variantId        String
  attributeValueId String
  variant          ProductVariant        @relation(fields: [variantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  attributeValue   ProductAttributeValue @relation(fields: [attributeValueId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@id([variantId, attributeValueId])
  @@index([attributeValueId])
  @@map("product_variant_attribute_value")
}

model CategoryAttribute {
  id              String                 @id @default(cuid())
  categoryId      String
  category        Category               @relation(fields: [categoryId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  attributeId     String
  attribute       ProductAttribute       @relation(fields: [attributeId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  scope           CategoryAttributeScope
  required        Boolean                @default(false)
  filterable      Boolean                @default(false)
  variantDefining Boolean                @default(false)
  comparable      Boolean                @default(false)
  inputType       AttributeInputType     @default(text)
  unit            String?
  groupName       String?
  helpText        String?                @db.Text
  placeholder     String?
  sortOrder       Int                    @default(0)
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  @@unique([categoryId, attributeId, scope])
  @@index([categoryId])
  @@index([attributeId])
  @@index([scope])
  @@index([filterable])
  @@index([variantDefining])
  @@index([sortOrder])
  @@map("category_attribute")
}

model ProductAttributeAssignment {
  id               String                 @id @default(cuid())
  productId        String
  product          Product                @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  attributeId      String
  attribute        ProductAttribute       @relation(fields: [attributeId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  attributeValueId String?
  attributeValue   ProductAttributeValue? @relation(fields: [attributeValueId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  rawText          String?                @db.Text
  rawNumber        Decimal?               @db.Decimal(16, 4)
  rawBoolean       Boolean?
  rawDate          DateTime?
  displayValue     String?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  values ProductAttributeAssignmentValue[]

  @@unique([productId, attributeId])
  @@index([productId])
  @@index([attributeId])
  @@index([attributeValueId])
  @@map("product_attribute_assignment")
}

model ProductAttributeAssignmentValue {
  assignmentId     String
  attributeValueId String
  assignment       ProductAttributeAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  attributeValue   ProductAttributeValue      @relation(fields: [attributeValueId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@id([assignmentId, attributeValueId])
  @@index([attributeValueId])
  @@map("product_attribute_assignment_value")
}

model Supplier {
  id          String   @id @default(cuid())
  name        String
  contactName String?
  email       String?
  phone       String?
  address     String?  @db.Text
  notes       String?  @db.Text
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  batches InventoryBatch[]

  @@index([isActive])
  @@index([email])
  @@map("supplier")
}

model InventoryLocation {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  address   String?  @db.Text
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stocks       InventoryStock[]
  movements    InventoryMovement[]
  reservations StockReservation[]

  @@index([isActive])
  @@map("inventory_location")
}

model InventoryBatch {
  id          String         @id @default(cuid())
  variantId   String
  variant     ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  supplierId  String?
  supplier    Supplier?      @relation(fields: [supplierId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  batchNumber String?
  expiryDate  DateTime?
  receivedAt  DateTime       @default(now())
  unitCost    Decimal?       @db.Decimal(12, 4)
  notes       String?        @db.Text

  stocks               InventoryStock[]
  movements            InventoryMovement[]
  reservations         StockReservation[]
  attributeAssignments InventoryBatchAttributeAssignment[]

  @@index([variantId])
  @@index([supplierId])
  @@index([expiryDate])
  @@map("inventory_batch")
}

model InventoryBatchAttributeAssignment {
  id               String                 @id @default(cuid())
  batchId          String
  batch            InventoryBatch         @relation(fields: [batchId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  attributeId      String
  attribute        ProductAttribute       @relation(fields: [attributeId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  attributeValueId String?
  attributeValue   ProductAttributeValue? @relation(fields: [attributeValueId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  rawText          String?                @db.Text
  rawNumber        Decimal?               @db.Decimal(16, 4)
  rawBoolean       Boolean?
  rawDate          DateTime?
  displayValue     String?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  @@unique([batchId, attributeId])
  @@index([batchId])
  @@index([attributeId])
  @@index([attributeValueId])
  @@map("inventory_batch_attribute_assignment")
}

model InventoryStock {
  id               String            @id @default(cuid())
  stockKey         String            @unique
  variantId        String
  variant          ProductVariant    @relation(fields: [variantId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  locationId       String
  location         InventoryLocation @relation(fields: [locationId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  batchId          String?
  batch            InventoryBatch?   @relation(fields: [batchId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  quantityOnHand   Int               @default(0)
  quantityReserved Int               @default(0)
  reorderLevel     Int?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@unique([variantId, locationId, batchId])
  @@index([variantId])
  @@index([locationId])
  @@index([batchId])
  @@map("inventory_stock")
}

model InventoryMovement {
  id            String                @id @default(cuid())
  variantId     String
  variant       ProductVariant        @relation(fields: [variantId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  locationId    String
  location      InventoryLocation     @relation(fields: [locationId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  batchId       String?
  batch         InventoryBatch?       @relation(fields: [batchId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  type          InventoryMovementType
  delta         Int
  unitCost      Decimal?              @db.Decimal(12, 4)
  reason        String?               @db.Text
  referenceType String?
  referenceId   String?
  actorUserId   String?
  actorUser     User?                 @relation("InventoryMovementActor", fields: [actorUserId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  createdAt     DateTime              @default(now())

  @@index([variantId, createdAt])
  @@index([locationId, createdAt])
  @@index([batchId])
  @@index([type, createdAt])
  @@index([referenceType, referenceId])
  @@index([actorUserId])
  @@map("inventory_movement")
}

model StockReservation {
  id            String                 @id @default(cuid())
  variantId     String
  variant       ProductVariant         @relation(fields: [variantId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  locationId    String
  location      InventoryLocation      @relation(fields: [locationId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  batchId       String?
  batch         InventoryBatch?        @relation(fields: [batchId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  quantity      Int
  status        StockReservationStatus @default(active)
  expiresAt     DateTime
  referenceType String?
  referenceId   String?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  @@index([variantId])
  @@index([locationId])
  @@index([batchId])
  @@index([status, expiresAt])
  @@index([referenceType, referenceId])
  @@map("stock_reservation")
}

model Order {
  id                  String               @id @default(cuid())
  orderNumber         String               @unique
  checkoutKey         String?              @unique
  userId              String?
  user                User?                @relation("UserOrders", fields: [userId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  customerName        String
  customerEmail       String
  customerPhone       String?
  subtotalAmount      Decimal              @default(0) @db.Decimal(12, 2)
  discountAmount      Decimal              @default(0) @db.Decimal(12, 2)
  taxAmount           Decimal              @default(0) @db.Decimal(12, 2)
  shippingAmount      Decimal              @default(0) @db.Decimal(12, 2)
  totalAmount         Decimal              @default(0) @db.Decimal(12, 2)
  currency            String               @default("BDT")
  paymentMethod       PaymentMethod        @default(cash_on_delivery)
  orderStatus         OrderStatus          @default(pending)
  paymentStatus       PaymentStatus        @default(unpaid)
  deliveryStatus      DeliveryStatus       @default(unfulfilled)
  inventoryStatus     OrderInventoryStatus @default(reserved)
  stockReservedUntil  DateTime?
  stockCommittedAt    DateTime?
  stockReleasedAt     DateTime?
  shippingRateId      String?
  shippingRate        ShippingRate?        @relation(fields: [shippingRateId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  shippingMethodCode  String?
  shippingMethodLabel String?
  customerNotes       String?              @db.Text
  adminNotes          String?              @db.Text
  placedAt            DateTime             @default(now())
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  addresses    OrderAddress[]
  lineItems    OrderLineItem[]
  statusEvents OrderStatusEvent[]

  @@index([userId])
  @@index([customerEmail])
  @@index([orderStatus])
  @@index([paymentStatus])
  @@index([deliveryStatus])
  @@index([inventoryStatus])
  @@index([paymentMethod])
  @@index([shippingRateId])
  @@index([placedAt])
  @@map("order")
}

model OrderAddress {
  id         String           @id @default(cuid())
  orderId    String
  order      Order            @relation(fields: [orderId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  type       OrderAddressType
  fullName   String
  email      String?
  phone      String?
  line1      String
  line2      String?
  city       String?
  state      String?
  postalCode String?
  country    String?
  notes      String?          @db.Text
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@unique([orderId, type])
  @@index([type])
  @@map("order_address")
}

model OrderLineItem {
  id                 String          @id @default(cuid())
  orderId            String
  order              Order           @relation(fields: [orderId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  productId          String?
  product            Product?        @relation(fields: [productId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  variantId          String?
  variant            ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  productName        String
  variantName        String?
  sku                String?
  imageUrl           String?
  attributesSnapshot Json?
  quantity           Int
  unitPrice          Decimal         @db.Decimal(12, 2)
  discountAmount     Decimal         @default(0) @db.Decimal(12, 2)
  taxAmount          Decimal         @default(0) @db.Decimal(12, 2)
  subtotalAmount     Decimal         @default(0) @db.Decimal(12, 2)
  totalAmount        Decimal         @default(0) @db.Decimal(12, 2)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@index([orderId])
  @@index([productId])
  @@index([variantId])
  @@map("order_line_item")
}

model ShippingRate {
  id             String   @id @default(cuid())
  code           String   @unique
  label          String
  amount         Decimal  @db.Decimal(12, 2)
  freeOverAmount Decimal? @db.Decimal(12, 2)
  isDefault      Boolean  @default(false)
  isActive       Boolean  @default(true)
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  orders Order[]

  @@index([isActive])
  @@index([isDefault])
  @@index([sortOrder])
  @@map("shipping_rate")
}

model OrderStatusEvent {
  id            String               @id @default(cuid())
  orderId       String
  order         Order                @relation(fields: [orderId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  type          OrderStatusEventType
  previousValue String?
  newValue      String
  note          String?              @db.Text
  metadata      Json?
  actorUserId   String?
  actorUser     User?                @relation("OrderStatusEventActor", fields: [actorUserId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  createdAt     DateTime             @default(now())

  @@index([orderId, createdAt])
  @@index([type, createdAt])
  @@index([actorUserId])
  @@map("order_status_event")
}

model Cart {
  id        String   @id @default(cuid())
  cartToken String?  @unique
  userId    String?
  user      User?    @relation("UserCarts", fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items CartItem[]

  @@index([userId])
  @@index([expiresAt])
  @@map("cart")
}

model CartItem {
  id        String         @id @default(cuid())
  cartId    String
  cart      Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  quantity  Int
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@unique([cartId, variantId])
  @@index([cartId])
  @@index([variantId])
  @@map("cart_item")
}
