{
  "extends": "../config/tsconfig.base.json",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "..",
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "paths": {
      "@env/*": ["../env/src/*"],
      "@config": ["../config/src/config.ts"]
    }
  },
  "include": [
    "src/**/*",
    "../env/src/**/*",
    "../config/src/**/*"
  ]
}
