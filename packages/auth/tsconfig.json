{
  "extends": "../config/tsconfig.base.json",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "jsx": "react-jsx",
    "outDir": "dist",
    "rootDir": "..",
    "baseUrl": ".",
    "paths": {
      "@db/server": ["../db/src/index.server.ts"],
      "@db/server/*": ["../db/src/*"],
      "@env/client": ["../env/src/env.client.ts"],
      "@env/server": ["../env/src/env.server.ts"],
      "@config": ["../config/src/config.ts"],
      "@config/brand": ["../config/src/brand.config.ts"],
      "@email/server": ["../email/src/index.server.ts"],
      "@rbac": ["../rbac/src/index.ts"]
    }
  },
  "include": [
    "src/**/*",
    "../db/src/**/*",
    "../rbac/src/**/*",
    "../email/src/**/*",
    "../env/src/**/*",
    "../config/src/**/*"
  ]
}
